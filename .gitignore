# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Keep lock file for reproducibility
!Terraform/.terraform.lock.hcl

# Terraform vars (keep dev/prod)
**/*.tfvars
!**/prod.tfvars
!**/dev.tfvars

# Binaries (should not be in repo)
kubectl.exe
helm.exe
agent.jar
*.exe

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Python
__pycache__/
*.pyc
.env

# Docker
docker/

# Empty/unused folders
kubernetes/jenkins/
kubernetes/namespaces/
